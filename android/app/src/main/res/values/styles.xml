<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Applied while the process is starting (before Flutter renders).
         Background matches the custom SplashScreen so there is no flash. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>

    <!-- Applied as soon as Flutter starts drawing — transparent so the
         Flutter SplashScreen is the only thing visible. -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/splash_bg</item>
    </style>
</resources>
